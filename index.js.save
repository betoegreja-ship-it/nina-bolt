import express from "express";
import dotenv from "dotenv";
import rateLimit from "express-rate-limit";
import helmet from "helmet";
import cors from "cors";

import { makeAnthropicClient } from "./services/anthropic.js";
import { validateInput } from "./services/validate.js";
import { executeBolt } from "./services/execute.js";
import { allMsgs } from "./memory/db.js"

dotenv.config();

const app = express();

// Segurança básica
app.use(helmet());
app.use(cors({ origin: true }));
app.use(express.json({ limit: "1mb" }));

// Rate limit (anti abuso)
app.use(
  rateLimit({
    windowMs: 60 * 1000, // 1 min
    max: 30, // 30 req/min por IP
    standardHeaders: true,
    legacyHeaders: false,
  })
);

const PORT = Number(process.env.PORT || 3000);
const MODEL = process.env.CLAUDE_MODEL || "claude-sonnet-4-6";

const apiKey = process.env.ANTHROPIC_API_KEY;
if (!apiKey) {
  console.error("Faltou ANTHROPIC_API_KEY no .env");
  process.exit(1);
}

const client = makeAnthropicClient(apiKey);

app.get("/health", (req, res) => {
  res.json({ ok: true, model: MODEL });
});

app.post("/bolt", async (req, res) => {
  const v = validateInput(req);
  if (!v.ok) return res.status(v.status).json({ error: v.error });

  try {
    const reply = await executeBolt({
      user_id: v.user_id,
      message: v.message,
      client,
      model: MODEL
    });
    res.json({ reply });
  } catch (err) {
    // log completo no servidor
    console.error("Claude error:", err?.status, err?.error?.error?.type, err?.error?.error?.message);
    res.status(500).json({ error: "Erro ao chamar Claude" });
  }
});

app.listen(PORT, () => {
  console.log(`Claude Bolt ON: http://localhost:${PORT}`);
  console.log(`MODEL: ${MODEL}`);
});
